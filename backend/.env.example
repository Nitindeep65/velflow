# Database configuration (PostgreSQL)
# SQLite fallback is supported out of the box if DATABASE_URL is left blank or set to sqlite:///./contracts.db
DATABASE_URL=sqlite:///./contracts.db

# Security & JWT Configuration
# Generate a secure secret key using: openssl rand -hex 32
JWT_SECRET_KEY=supersecretkeyfortestingpurposesonly12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Upload directory configuration
UPLOAD_DIR=./uploads

